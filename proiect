    inline void afisareDomeniu(Facultate& f, int i) const;

    class Domeniu{
        string nume;
        int nr_discipline;
        vector<string> discipline;
        int nr_studenti_taxa;
        int nr_studenti_buget;
        string semestru;
        float medie_admitere_buget;
